# ElevenLabs narration config for docs/demos/lib/narrate.py.
# Copy this file to docs/demos/lib/.env (gitignored) and fill in real values.
# Sourced by narrate.py via python-dotenv. Shell env vars override these.

# Required.
ELEVENLABS_API_KEY=

# Required. Pick from https://elevenlabs.io/app/voice-library or `client.voices.get_all()`.
ELEVENLABS_VOICE_ID=

# Optional. Defaults to eleven_multilingual_v2 if unset.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional. Defaults to mp3_44100_128 if unset.
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
